{
  "name": "gh-block-spam-accounts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && esbuild src/github-action/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=.github/actions/spam-blocker/index.js",
    "build:action": "esbuild src/github-action/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=.github/actions/spam-blocker/index.js",
    "format": "biome format . --write",
    "lint": "biome lint .",
    "check": "bunx --bun @biomejs/biome check --write",
    "check:action": "tsc -p tsconfig.action.json",
    "lint:eslint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/happy-work-theme": "^2.0.0",
    "@ant-design/icons": "^6.2.5",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@octokit/rest": "^22.0.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "antd": "^6.4.4",
    "octokit": "^5.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@babel/core": "^7.29.7",
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
